# The backend the packaged desktop app connects to.
# There is no hosted Ohiyo backend — you self-host your own. Build the server from
# source (see DEPLOY.md / GO-LIVE.md), deploy it (e.g. to Fly), and point this at it:
# replace the placeholder below with your own https://<your-app>.fly.dev, then rebuild
# the desktop app.
VITE_SERVER_URL=https://your-server.fly.dev
