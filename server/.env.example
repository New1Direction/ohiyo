# ── Ohiyo server configuration ────────────────────────────────────────────
# Local dev: copy this to `.env` (cd server && cp .env.example .env).
# Production: set these as Fly secrets (`fly secrets set KEY=value`), NOT in fly.toml.

# REQUIRED in production (≥32 chars). Signs session tokens. Release builds REFUSE to
# start without it; dev builds generate an ephemeral secret (sessions reset on every
# restart). Generate one: `openssl rand -base64 48`
JWT_SECRET=

# REQUIRED in production. Public URL of THIS backend (e.g. https://your-app.fly.dev).
# It prefixes avatar/banner URLs that are PERSISTED to the database, so an unset or
# wrong value bakes unreachable links in permanently. Release builds refuse to start
# without it; dev defaults to http://localhost:3000.
PUBLIC_BASE_URL=

# Optional CORS allowlist (comma-separated origins). Unset = permissive, which is fine
# for the bearer-token desktop client (auth is via the Authorization header, not
# cookies). To lock down, set e.g.:
#   CORS_ALLOWED_ORIGINS=tauri://localhost,https://tauri.localhost
CORS_ALLOWED_ORIGINS=

# SQLite database location. Local default below; production uses /data on the volume.
DATABASE_URL=sqlite:kikkacord.db

# Address the server binds to.
BIND_ADDR=0.0.0.0:3000

# Log filter.
RUST_LOG=server=info,tower_http=warn

# ── Voice (WebRTC TURN/STUN) ──────────────────────────────────────────────────
# Leave TURN_* unset for LAN-only (STUN-only) testing. For real internet calls,
# stand up coturn (see infra/coturn/) and set these. TURN_SECRET must match the
# coturn `static-auth-secret`.
TURN_SECRET=
TURN_URLS=
TURN_TTL=86400
STUN_URLS=stun:stun.l.google.com:19302

# ── Link-preview embeds ───────────────────────────────────────────────────────
# When true, the server resolves URLs in messages into Open Graph embed cards
# (off the request path) and persists them. Off by default — it makes outbound
# fetches on your users' behalf, so opt in deliberately.
EMBEDS_ENABLED=false

# ── Full-text search (Meilisearch) ────────────────────────────────────────────
# When enabled, message search uses Meilisearch (see infra/meilisearch/). When
# disabled, search falls back to a SQL LIKE query — no client change either way.
MEILISEARCH_ENABLED=false
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=

# ── Voice SFU (LiveKit) ───────────────────────────────────────────────────────
# Optional scalable group-voice path (see infra/livekit/). When disabled, calls
# use the built-in peer-to-peer WebRTC mesh. API key/secret must match livekit.yaml.
LIVEKIT_ENABLED=false
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
