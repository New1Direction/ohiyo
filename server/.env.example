# ── Kikkacord server configuration ────────────────────────────────────────────
# Local dev: copy this to `.env` (cd server && cp .env.example .env).
# Production: set these as Fly secrets (`fly secrets set KEY=value`), NOT in fly.toml.

# REQUIRED in production. Signs session tokens. If unset, the server generates an
# ephemeral secret per process — sessions then reset on every restart.
# Generate one: `openssl rand -base64 48`
JWT_SECRET=

# SQLite database location. Local default below; production uses /data on the volume.
DATABASE_URL=sqlite:kikkacord.db

# Address the server binds to.
BIND_ADDR=0.0.0.0:3000

# Log filter.
RUST_LOG=server=info,tower_http=warn

# ── Voice (WebRTC TURN/STUN) ──────────────────────────────────────────────────
# Leave TURN_* unset for LAN-only (STUN-only) testing. For real internet calls,
# stand up coturn (see infra/coturn/) and set these. TURN_SECRET must match the
# coturn `static-auth-secret`.
TURN_SECRET=
TURN_URLS=
TURN_TTL=86400
STUN_URLS=stun:stun.l.google.com:19302
